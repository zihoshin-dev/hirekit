[0.421, "o", "\u001b[3m                                  Data Sources                                  \u001b[0m\r\n┏━━━━━━━━━━━━━━━┳━━━━━━━━┳━━━━━━━━━━━━━━━━━━━━━━━━━━┳━━━━━━━━━━━━━━━━━┳━━━━━━━━┓\r\n┃\u001b[1m \u001b[0m\u001b[1mName         \u001b[0m\u001b[1m \u001b[0m┃\u001b[1m \u001b[0m\u001b[1mRegion\u001b[0m\u001b[1m \u001b[0m┃\u001b[1m \u001b[0m\u001b[1mSections                \u001b[0m\u001b[1m \u001b[0m┃\u001b[1m \u001b[0m\u001b[1mAPI Key        \u001b[0m\u001b[1m \u001b[0m┃\u001b[1m \u001b[0m\u001b[1mStatus\u001b[0m\u001b[1m \u001b[0m┃\r\n┡━━━━━━━━━━━━━━━╇━━━━━━━━╇━━━━━━━━━━━━━━━━━━━━━━━━━━╇━━━━━━━━━━━━━━━━━╇━━━━━━━━┩\r\n│\u001b[36m \u001b[0m\u001b[36mbrave_search \u001b[0m\u001b[36m \u001b[0m│ GLOBAL │ overview, industry,      │ BRAVE_API_KEY   │ \u001b[32mReady\u001b[0m  │\r\n│\u001b[36m               \u001b[0m│        │ culture                  │                 │        │\r\n│"]
[0.000, "o", "\u001b[36m \u001b[0m\u001b[36mcredible_news\u001b[0m\u001b[36m \u001b[0m│ GLOBAL │ overview, strategy,      │ -               │ \u001b[32mReady\u001b[0m  │\r\n│\u001b[36m               \u001b[0m│        │ industry                 │                 │        │\r\n│\u001b[36m \u001b[0m\u001b[36mdart         \u001b[0m\u001b[36m \u001b[0m│ KR     │ overview, financials     │ DART_API_KEY    │ \u001b[32mReady\u001b[0m  │\r\n│\u001b[36m \u001b[0m\u001b[36mexa_search   \u001b[0m\u001b[36m \u001b[0m│ GLOBAL │ overview, tech, culture, │ EXA_API_KEY     │ \u001b[32mReady\u001b[0m  │\r\n│\u001b[36m               \u001b[0m│        │ strategy                 │                 │        │\r\n│\u001b[36m \u001b[0m\u001b[36mgithub       \u001b[0m\u001b[36m \u001b[0m│ GLOBAL │ tech                     │ -               │ \u001b[32mReady\u001b[0m  │\r\n│\u001b[36m \u001b[0m\u001b[36mgoogle_news  \u001b[0m\u001b[36m \u001b[0m│ GLOBAL │ overview, strategy,      │ -               │ \u001b[32mReady\u001b[0m  │\r\n│\u001b[36m               \u001b[0m│        │ industry                 │                 │        │\r\n│\u001b[36m \u001b[0m\u001b[36mnaver_news   \u001b[0m\u001b[36m \u001b[0m│ KR     │ overview"]
