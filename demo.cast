[0.001, "o", "\u001b[32m⠋\u001b[0m \u001b[1;32mPreparing interview guide for 카카오...\u001b[0m\r\n\u001b[?25h\r\u001b[1A\u001b[2K"]
[0.000, "o", "\u001b[34m╭─\u001b[0m\u001b[34m──────────────────────────────\u001b[0m\u001b[34m \u001b[0m\u001b[1;34mInterview Prep\u001b[0m\u001b[34m \u001b[0m\u001b[34m──────────────────────────────\u001b[0m\u001b[34m─╮\u001b[0m\r\n\u001b[34m│\u001b[0m \u001b[1m카카오\u001b[0m — PM                                                                  \u001b[34m│\u001b[0m\r\n\u001b[34m│\u001b[0m Questions: 5 common, 0 technical, 0 behavioral                               \u001b[34m│\u001b[0m\r\n\u001b[34m│\u001b[0m Reverse questions: 5                                                         \u001b[34m│\u001b[0m\r\n\u001b[34m╰──────────────────────────────────────────────────────────────────────────────╯\u001b[0m\r\n"]
[0.001, "o", "\r\n\u001b[36mQ:\u001b[0m Why do you want to join 카카오?\r\n"]
[0.000, "o", "  \u001b[2mConnect your career goals with the company's mission and recent strategy.\u001b[0m\r\n"]
[0.000, "o", "\r\n\u001b[36mQ:\u001b[0m Why this role specifically?\r\n"]
[0.000, "o", "  \u001b[2mMap your skills and experience to the role requirements.\u001b[0m\r\n"]
[0.000, "o", "\r\n\u001b[36mQ:\u001b[0m Tell me about your biggest achievement.\r\n"]
[0.000, "o", "  \u001b[2mUse STAR format. Include quantitative results.\u001b[0m\r\n"]
[0.000, "o", "\r\n\u001b[36mQ:\u001b[0m Where do you see yourself in \u001b[1;36m3\u001b[0m-\u001b[1;36m5\u001b[0m years?\r\n"]
[0.000, "o", "  \u001b[2mAlign with the company's growth trajectory and your role's growth path.\u001b[0m\r\n"]
[0.001, "o", "\r\n\u001b[36mQ:\u001b[0m Why are you leaving your current role?\r\n"]
[0.000, "o", "  \u001b[2mFocus on growth opportunities, not complaints. Be positive.\u001b[0m\r\n"]
[0.013, "o", "\r\n"]
