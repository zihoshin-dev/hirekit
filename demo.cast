[0.000, "o", "\u001b[32m╭─\u001b[0m\u001b[32m─────────────────────────────\u001b[0m\u001b[32m Analysis Report \u001b[0m\u001b[32m──────────────────────────────\u001b[0m\u001b[32m─╮\u001b[0m\r\n\u001b[32m│\u001b[0m \u001b[1;36m카카오\u001b[0m                                                                       \u001b[32m│\u001b[0m\r\n\u001b[32m│\u001b[0m \u001b[1mGrade: D | \u001b[0mScore: 0/100                                                      \u001b[32m│\u001b[0m\r\n\u001b[32m│\u001b[0m Sources: 4 collected                                                         \u001b[32m│\u001b[0m\r\n\u001b[32m│\u001b[0m                                                                              \u001b[32m│\u001b[0m\r\n\u001b[32m│\u001b[0m \u001b[1;33m[1] Company Overview\u001b[0m                                                         \u001b[32m│\u001b[0m\r\n\u001b[32m│\u001b[0m                                                                              \u001b[32m│\u001b[0m\r\n\u001b[32m╰───────────────────────────────────"]
[0.000, "o", "───────────────────────────────────────────╯\u001b[0m\r\n"]
[0.002, "o", "\u001b[3m                   카카오 Scorecard                    \u001b[0m\r\n┏━━━━━━━━━━━━━━━━━━━━━━━━━┳━━━━━━━━┳━━━━━━━┳━━━━━━━━━━┓\r\n┃\u001b[1m \u001b[0m\u001b[1mDimension              \u001b[0m\u001b[1m \u001b[0m┃\u001b[1m \u001b[0m\u001b[1mWeight\u001b[0m\u001b[1m \u001b[0m┃\u001b[1m \u001b[0m\u001b[1mScore\u001b[0m\u001b[1m \u001b[0m┃\u001b[1m \u001b[0m\u001b[1mEvidence\u001b[0m\u001b[1m \u001b[0m┃\r\n┡━━━━━━━━━━━━━━━━━━━━━━━━━╇━━━━━━━━╇━━━━━━━╇━━━━━━━━━━┩\r\n│\u001b[36m \u001b[0m\u001b[36mJob Fit                \u001b[0m\u001b[36m \u001b[0m│    30% │     - │          │\r\n│\u001b[36m \u001b[0m\u001b[36mCareer Leverage        \u001b[0m\u001b[36m \u001b[0m│    20% │     - │          │\r\n│\u001b[36m \u001b[0m\u001b[36mGrowth Potential       \u001b[0m\u001b[36m \u001b[0m│    20% │     - │          │\r\n│\u001b[36m \u001b[0m\u001b[36mCompensation & Benefits\u001b[0m\u001b[36m \u001b[0m│    15% │     - │          │\r\n│\u001b[36m \u001b[0m\u001b[36mCulture Fit            \u001b[0m\u001b[36m \u001b[0m│    15% │     - │    "]
